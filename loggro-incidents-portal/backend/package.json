{
  "name": "loggro-incidents-portal-backend",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "intercom:discover": "ts-node --transpile-only src/scripts/intercom-discover.ts",
    "intercom:sync": "ts-node --transpile-only src/scripts/intercom-sync.ts",
    "intercom:test": "ts-node --transpile-only src/scripts/intercom-test.ts",
    "validate": "ts-node --transpile-only src/tests/validate.ts"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "better-sqlite3": "^9.6.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^11.1.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.9",
    "@types/uuid": "^10.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.2"
  }
}
