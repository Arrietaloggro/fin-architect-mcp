# ============================================================
# Portal Interno de Incidencias Loggro — Backend Configuration
# ============================================================
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env al repositorio.

# ─── SERVIDOR ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS ───────────────────────────────────────────────────
# En producción usa el dominio real del frontend
CORS_ORIGIN=http://localhost:5173

# ─── SEGURIDAD ──────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=cambia-esto-por-un-string-aleatorio-de-al-menos-32-caracteres

# Clave para acceder al Dashboard de Administración
# Genera con: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
ADMIN_API_KEY=cambia-esto-por-una-clave-segura

# Dominio permitido para registro de incidencias
ALLOWED_EMAIL_DOMAIN=loggro.com

# ─── INTERCOM ───────────────────────────────────────────────
# Token de acceso a la API de Intercom (Settings > Integrations > API Keys)
INTERCOM_ACCESS_TOKEN=your_intercom_access_token_here

# Versión de la API de Intercom
INTERCOM_API_VERSION=2.11

# IDs de Ticket Type por producto (crear en Intercom: Settings > Tickets > Ticket Types)
# Puedes dejar vacíos los que aún no hayas configurado en Intercom
INTERCOM_TICKET_TYPE_ERP_PYMES=
INTERCOM_TICKET_TYPE_RESTOBAR=
INTERCOM_TICKET_TYPE_POS_TIENDA=
INTERCOM_TICKET_TYPE_NOMINA=
INTERCOM_TICKET_TYPE_ALOJAMIENTOS=
INTERCOM_TICKET_TYPE_ENTERPRISE=

# ─── BASE DE DATOS ───────────────────────────────────────────
# Ruta al archivo SQLite (relativa al directorio del backend)
DATABASE_PATH=./data/portal.db

# ─── ARCHIVOS ADJUNTOS ───────────────────────────────────────
MAX_FILE_SIZE_MB=10
MAX_FILES_PER_REQUEST=5
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

# ─── RATE LIMITING ───────────────────────────────────────────
# Ventana de tiempo en milisegundos (900000 = 15 minutos)
RATE_LIMIT_WINDOW_MS=900000
# Máximo de solicitudes de creación de ticket por ventana, por IP
RATE_LIMIT_MAX_REQUESTS=5

# ─── LOGGING ─────────────────────────────────────────────────
# Niveles: error, warn, info, debug
LOG_LEVEL=info
